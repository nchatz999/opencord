  "query": "SELECT message_id, channel_id, user_id, message_text, created_at, modified_at, deleted_at, reply_to_message_id\n                 FROM messages \n                 WHERE channel_id = $1 AND message_id < $2 AND deleted_at IS NULL\n                 ORDER BY message_id DESC \n                 LIMIT $3",
