  "query": "SELECT \n                c.channel_id, \n                c.channel_name, \n                c.group_id,\n                c.channel_type as \"channel_type: ChannelTypeSQL\"\n            FROM channels c\n            JOIN channel_role_rights cr ON c.channel_id = cr.channel_id\n            WHERE cr.role_id = $1 AND cr.rights >= 1",
