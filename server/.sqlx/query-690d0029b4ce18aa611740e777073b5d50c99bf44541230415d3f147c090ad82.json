{
  "db_name": "PostgreSQL",
  "query": "SELECT message_id, channel_id, user_id, message_text, created_at, modified_at, deleted_at, reply_to_message_id \n             FROM messages \n             WHERE channel_id = $1 \n             AND (created_at > $2 OR modified_at > $2 OR deleted_at > $2)\n             ORDER BY GREATEST(created_at, COALESCE(modified_at, created_at), COALESCE(deleted_at, created_at)) ASC\n             LIMIT $3",
