{
  "name": "opencord-transport",
  "version": "0.1.0",
  "description": "Opencord transport layer",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts"
  },
  "keywords": [
    "webtransport",
    "multiplexer",
    "real-time",
    "networking"
  ],
  "author": "nchatz999@gmail.com",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "msgpack-lite": "^0.1.26",
    "opencord-utils": "*"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "tsdown": "^0.16.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@fails-components/webtransport": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@fails-components/webtransport": {
      "optional": true
    }
  }
}
